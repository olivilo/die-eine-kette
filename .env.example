# ─── LM Studio (lokale Übersetzungen) ────────────────────────────────
# OpenAI-kompatibler Endpunkt. Lokal oder über LAN-IP erreichbar.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=sk-lm-xxxxxxxxxxxxxxxx
# Leer lassen = erstes geladenes Modell automatisch verwenden
LMSTUDIO_MODEL=

# ─── Kostenmodell: Self-Hosted-Standardwerte (überschreibbar je Node) ─
ELECTRICITY_EUR_PER_KWH=0.32

# ─── Lizenz (kommerzielle Nutzung) ───────────────────────────────────
# Öffentlicher Verifikations-Key (Ed25519) ist im Build eingebacken.
# Der private Signier-Key liegt NUR bei dir (Keygen, privater Teil), nie im Repo.
# Lizenz als Token direkt setzen ODER als Datei. Leer = Community-Limits.
DIEEINEKETTE_LICENSE=
DIEEINEKETTE_LICENSE_FILE=./license.key

# ─── App / Stack (docker-compose) ────────────────────────────────────
# Port, unter dem die App erreichbar ist.
APP_PORT=3000
# Zeitzone für App + Datenbank.
TZ=Europe/Berlin
# Session-Geheimnis — UNBEDINGT durch langen Zufallswert ersetzen!
# z. B.:  openssl rand -hex 32
SESSION_SECRET=change-me-zu-langem-zufallswert

# ─── PostgreSQL (vom Compose-Stack genutzt) ──────────────────────────
POSTGRES_USER=dieeinekette
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dieeinekette
# Hinweis: Der Relay-Motor erhält daraus automatisch SQL_DSN=postgres://…
#          und REDIS_CONN_STRING=redis://redis:6379/0 (siehe docker-compose.yml).
