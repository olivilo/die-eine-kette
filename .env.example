# ─── LM Studio (lokale Übersetzungen) ────────────────────────────────
# OpenAI-kompatibler Endpunkt. Lokal oder über LAN-IP erreichbar.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=sk-lm-xxxxxxxxxxxxxxxx
# Leer lassen = erstes geladenes Modell automatisch verwenden
LMSTUDIO_MODEL=

# ─── Kostenmodell: Self-Hosted-Standardwerte (überschreibbar je Node) ─
ELECTRICITY_EUR_PER_KWH=0.32

# ─── Lizenz (kommerzielle Nutzung) ───────────────────────────────────
# Öffentlicher Verifikations-Key (Ed25519) ist im Build eingebacken.
# Der private Signier-Key liegt NUR bei dir (License-Server), nie im Repo.
DIEEINEKETTE_LICENSE_FILE=./license.key

# ─── Datenbank / Cache (Phase 1+) ────────────────────────────────────
DATABASE_URL=postgres://dieeinekette:change-me@localhost:5432/dieeinekette
REDIS_URL=redis://localhost:6379/0
